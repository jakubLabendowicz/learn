{/*
  Loads the local-storage data layer: storage -> dao -> repository ->
  per-entity Dao/Repository files -> seed bootstrap. Every one of these
  is a classic (non-module) script relying on shared global scope
  (e.g. `class CourseDao extends Dao`), so `is:inline` is required —
  without it Astro would process each as an isolated ES module and the
  cross-file globals would break.
*/}
<script is:inline src="/assets/storage.js"></script>
<script is:inline src="/assets/dao.js"></script>
<script is:inline src="/assets/repository.js"></script>
<script is:inline src="/assets/data/question.js"></script>
<script is:inline src="/assets/data/question-set.js"></script>
<script is:inline src="/assets/data/quiz-question-set.js"></script>
<script is:inline src="/assets/data/article.js"></script>
<script is:inline src="/assets/data/quiz.js"></script>
<script is:inline src="/assets/data/module.js"></script>
<script is:inline src="/assets/data/course.js"></script>
<script is:inline src="/assets/data/user.js"></script>
<script is:inline src="/assets/data/user-course-activity.js"></script>
<script is:inline src="/assets/data/user-module-activity.js"></script>
<script is:inline src="/assets/data/user-article-activity.js"></script>
<script is:inline src="/assets/data/user-quiz-activity.js"></script>
<script is:inline src="/assets/data/user-quiz-attempt.js"></script>
<script is:inline src="/assets/seed.js"></script>
